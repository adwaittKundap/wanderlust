<% layout("/layout/boilerplate") %>

    <body>
        <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

            <body class="bg-light">

                <div class="container mt-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-8 col-md-10 col-sm-12">

                            <div class="card shadow-sm border-0 p-4">
                                <h3 class="mb-4">Create a New Listing</h3>

                                <form>

                                    <!-- Title -->
                                    <div class="mb-3">
                                        <label class="form-label">Title</label>
                                        <input name="listing[title]" type="text" class="form-control"
                                            placeholder="Add a catchy title" required>
                                        <div class="invalid-feedback">Please enter valid title</div>
                                        <div class="valid-feedback">Tile looks good</div>
                                    </div>

                                    <!-- Description -->
                                    <div class="mb-3">
                                        <label class="form-label">Description</label>
                                        <textarea name="listing[description]" class="form-control" rows="3"
                                            required></textarea>
                                        <div class="invalid-feedback">Enter short description</div>
                                    </div>

                                    <!-- Image Link -->
                                    <div class="mb-3">
                                        <label for="image" class="form-label">Image Link</label>
                                        <input name="listing[image]" type="file" class="form-control"
                                            placeholder="enter image URL/link">
                                    </div>

                                    <!-- Price & Country -->
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Price</label>
                                            <input name="listing[price]" type="number" class="form-control" required>
                                            <div class="invalid-feedback">Enter valid price</div>
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Country</label>
                                            <input name="listing[country]" type="text" class="form-control" required>
                                            <div class="invalid-feedback">Enter valid country</div>
                                        </div>
                                    </div>

                                    <!-- Location -->
                                    <div class="mb-4">
                                        <label class="form-label">Location</label>
                                        <input name="listing[location]" type="text" class="form-control" required>
                                        <div class="invalid-feedback">Enter a valid location</div>
                                    </div>

                                    <!-- Button -->
                                    <button type="submit" class="btn btn-dark px-4">
                                        Add
                                    </button>

                                </form>
                            </div>

                        </div>
                    </div>
                </div>
        </form>

    </body>