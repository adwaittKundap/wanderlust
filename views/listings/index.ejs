<% layout("/layout/boilerplate") %>

    <body>
        <!---<---form action="/listings/new"><button>Create new</button></form>--->
        <div class="row g-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
            <% for(let listning of allListings){ %>

                <a href="/listings/<%=listning._id%>" class="listing-link">
                    <div class="card col">
                        <img src="<%= listning.image?.url || 'https://via.placeholder.com/800x600?text=No+Image' %>"
                            class="card-img-top" alt="listing_image" style="height:20rem" />


                        <div class="card-img-overlay"> </div>
                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%=listning.title%><br>&#8377;
                                        <%= listning.price.toLocaleString("en-IN") %>
                                </b>
                            </p>
                        </div>

                    </div>
                </a>
                <% } %>
        </div>

    </body>