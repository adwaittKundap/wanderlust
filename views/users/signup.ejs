<% layout("/layout/boilerplate") %>
    <link rel="stylesheet" href="/css/login.css">


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <form action="/signup" method="post">
        <div class="d-flex justify-content-center align-items-center min-vh-100 galaxy-bg">

            <div class="galaxy-card p-4">
                <h4 class="text-center mb-4 text-white">SignUp for listing</h4>

                <div class="mb-3">
                    <label class="form-label text-light">Username</label>
                    <input name="username" type="text" class="form-control galaxy-input"
                        placeholder="Add a catchy Username">
                </div>

                <div class="mb-3">
                    <label class="form-label text-light">Email</label>
                    <input name="email" type="email" class="form-control galaxy-input" placeholder="Add an email">
                </div>

                <div class="mb-4">
                    <label class="form-label text-light">Password</label>
                    <input name="password" type="password" class="form-control galaxy-input"
                        placeholder="Add a strong password">
                </div>

                <button class="btn galaxy-btn w-100">Sign Up</button>
            </div>

        </div>
    </form>